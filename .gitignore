# ─── Foundry 标准忽略项 ──────────────────────────────────────────────────
# 编译输出（默认 profile + 所有教学 profile）
out/
out-*/

# 编译缓存
cache/

# 部署广播记录（含未上链时的私钥引用等敏感信息）
broadcast/

# 单元测试覆盖率
lcov.info
coverage/

# 调试 / 火焰图等
*.dbg
*.gas-snapshot.tmp

# ─── 依赖 / 工具 ─────────────────────────────────────────────────────────
node_modules/

# ─── 本地环境变量（私钥 / RPC 等敏感数据）⚠️ 千万别提交 ─────────────────
.env
.env.*
!.env.example

# ─── IDE / 编辑器 ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── 操作系统 ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
